    "@tanstack/react-query": "^5.90.21",
    "@testing-library/react-native": "^13.3.3",
    "axios": "^1.13.6",
    "babel-preset-expo": "^55.0.10",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "env-var": "^7.5.0",
    "expo": "^55.0.5",
    "expo-application": "~55.0.8",
    "expo-asset": "~55.0.8",
