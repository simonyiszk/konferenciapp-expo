{
  "name": "konferenciapp",
  "version": "4.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "lint": "eslint \"./**/*.ts?(x)\" --fix",
